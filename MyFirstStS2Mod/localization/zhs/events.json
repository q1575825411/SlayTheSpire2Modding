  "MY_FIRST_ST_S2_MOD_EVENT_WEN_JI_EVENT.pages.INITIAL.options.MY_FIRST_ST_S2_MOD_RELIC_JIN_NANG_CAN_YE_RELIC.title": "虚心求教",
  "MY_FIRST_ST_S2_MOD_EVENT_WEN_JI_EVENT.pages.INITIAL.options.MY_FIRST_ST_S2_MOD_RELIC_JIN_NANG_CAN_YE_RELIC.description": "获得事件遗物【锦囊残页】。",
  "MY_FIRST_ST_S2_MOD_EVENT_WEN_JI_EVENT.pages.INITIAL.options.ROUGH_QUESTIONING.title": "强行盘问",
  "MY_FIRST_ST_S2_MOD_EVENT_WEN_JI_EVENT.pages.INITIAL.options.ROUGH_QUESTIONING.description": "获得125金币。将1张【懊悔】加入牌组。",
  "MY_FIRST_ST_S2_MOD_EVENT_WEN_JI_EVENT.pages.RECEIVED_RELIC.description": "老者轻叹一声，将一页残简交到你手里。其上寥寥数笔，却像另有后文。",
  "MY_FIRST_ST_S2_MOD_EVENT_WEN_JI_EVENT.pages.ROUGH_QUESTIONING_RESULT.description": "你逼问出几句有用的话，也抢下了一些财物。但那份急躁像阴影一样留在了牌组里。",

  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.title": "酒肆",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.INITIAL.description": "道旁酒肆未见宾客，只有一坛新开封的酒散着浓烈气味。店家笑着招呼你落座。",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.INITIAL.options.DRINK_DEEPLY.title": "痛饮",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.INITIAL.options.DRINK_DEEPLY.description": "失去125金币。获得1张升级的【酒】。",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.INITIAL.options.SIP_LIGHTLY.title": "浅尝",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.INITIAL.options.SIP_LIGHTLY.description": "失去50金币。获得1张【酒】。",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.INITIAL.options.DECLINE.title": "离开",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.INITIAL.options.DECLINE.description": "什么也不做。",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.DRINK_DEEPLY_RESULT.description": "烈酒入喉，胆气先涨了三分。你付了钱，带走一坛最冲的。",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.SIP_LIGHTLY_RESULT.description": "你只抿了一口，却也足够暖身。店家递来一小壶，算是顺手买下的。",
  "MY_FIRST_ST_S2_MOD_EVENT_JIU_SI_EVENT.pages.DECLINE_RESULT.description": "你摇了摇头，转身继续赶路，把酒气留在了身后。",

  "MY_FIRST_ST_S2_MOD_EVENT_LIU_MIN_YING_EVENT.title": "流民营",
  "MY_FIRST_ST_S2_MOD_EVENT_LIU_MIN_YING_EVENT.pages.INITIAL.description": "破旧帐篷连成一片，营地里的流民正守着不多的粮食。远处还有几名不怀好意的人在打量这里。",
  "MY_FIRST_ST_S2_MOD_EVENT_LIU_MIN_YING_EVENT.pages.INITIAL.options.DISTRIBUTE_SUPPLIES.title": "接济粮草",
