  "MY_FIRST_ST_S2_MOD_EVENT_LU_YU_HAO_JIE_EVENT.pages.INITIAL.options.MY_FIRST_ST_S2_MOD_RELIC_HAO_JIE_RELIC.description": "获得事件遗物【豪杰】。",
  "MY_FIRST_ST_S2_MOD_EVENT_LU_YU_HAO_JIE_EVENT.pages.INITIAL.options.MY_FIRST_ST_S2_MOD_RELIC_HAO_JIE_YOU_YI_RELIC.title": "留下一份情谊",
  "MY_FIRST_ST_S2_MOD_EVENT_LU_YU_HAO_JIE_EVENT.pages.INITIAL.options.MY_FIRST_ST_S2_MOD_RELIC_HAO_JIE_YOU_YI_RELIC.description": "获得事件遗物【豪杰的友谊】。",
